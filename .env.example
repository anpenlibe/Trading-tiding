# Emergency Threshold Configuration Example
# These values control the default thresholds for AI monitoring system
# Values are percentages (e.g., -3.5 means -3.5%)

# Default emergency stop loss percentage (negative value)
EMERGENCY_STOP_LOSS_PCT=-3.5

# Default emergency take profit percentage (positive value)
EMERGENCY_TAKE_PROFIT_PCT=4.0

# Default recheck trigger percentage (absolute value)
EMERGENCY_RECHECK_PCT=2.0

# Example: More conservative settings
# EMERGENCY_STOP_LOSS_PCT=-2.0
# EMERGENCY_TAKE_PROFIT_PCT=3.0
# EMERGENCY_RECHECK_PCT=1.5

# Example: More aggressive settings
# EMERGENCY_STOP_LOSS_PCT=-5.0
# EMERGENCY_TAKE_PROFIT_PCT=8.0
# EMERGENCY_RECHECK_PCT=3.0