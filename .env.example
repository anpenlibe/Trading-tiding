# ==========================================================================
# trading-tiding configuration
# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored and must NEVER be committed.
# ==========================================================================

# --------------------------------------------------------------------------
# AI provider keys (at least ONE is required)
# Multi-provider fallback chain: Groq -> Gemini -> Claude -> rule-based
# (defined in src/ai/provider_coordinator.py).
# --------------------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# Provider allowlist for the fallback chain (comma-separated).
# A provider is used only if it is listed here AND its API key is set.
# e.g. set "groq,gemini" to disable Claude without removing the key.
ENABLED_AI_PROVIDERS=groq,gemini,claude

# Claude model/token overrides — the ONLY per-provider knobs read at runtime.
# The Groq and Gemini models are fixed in the coordinator's chain (no
# GROQ_MODEL / GEMINI_MODEL knobs), and temperature is set in code.
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1024

# --------------------------------------------------------------------------
# Market data — Zerodha Kite Connect (optional; falls back to yfinance/mock)
# --------------------------------------------------------------------------
ZERODHA_API_KEY=your-zerodha-api-key-here
ZERODHA_API_SECRET=your-zerodha-api-secret-here
ZERODHA_ACCESS_TOKEN=your-zerodha-access-token-here

# Data-source priority (Zerodha -> Yahoo -> Mock) is automatic; there is no
# single source switch. USE_MOCK_DATA forces mock data in paper/test only.
USE_MOCK_DATA=false

# --------------------------------------------------------------------------
# Runtime / environment
# --------------------------------------------------------------------------
ENVIRONMENT=development        # development | production
DEBUG_MODE=false
DRY_RUN=true                   # true = paper trading only (recommended)
TEST_MODE=false
LOG_LEVEL=INFO

# --------------------------------------------------------------------------
# Trading parameters
# --------------------------------------------------------------------------
INITIAL_CAPITAL=10000.0
MAX_RISK_PER_TRADE=0.015       # 1.5% of capital risked per trade
MAX_DAILY_LOSS=0.05            # 5% daily loss limit
MAX_DRAWDOWN=0.15              # 15% max drawdown
TRADING_MODE=paper             # paper | live  (paper = simulation, default; live is gated)
TRADING_STRATEGY=swing         # conservative | swing | diversified | tech_focus

# Position sizing & exits
MAX_POSITION_SIZE=0.20         # max fraction of capital per position
STOP_LOSS_PERCENT=0.015        # 1.5% stop loss
TAKE_PROFIT_PERCENT=0.03       # 3% take profit
PRICE_ALERT_THRESHOLD=0.02     # 2% move triggers a price alert

# Paper-trading simulation costs
PAPER_TRADE_COMMISSION=0.0     # per-trade commission (fraction)
PAPER_TRADE_SLIPPAGE=0.0005    # 5 bps simulated slippage

# --------------------------------------------------------------------------
# Emergency thresholds (percentages; AI monitoring triggers)
# --------------------------------------------------------------------------
EMERGENCY_STOP_LOSS_PCT=-3.5
EMERGENCY_TAKE_PROFIT_PCT=4.0
EMERGENCY_RECHECK_PCT=2.0

# --------------------------------------------------------------------------
# Data validation & caching
# --------------------------------------------------------------------------
VALIDATION_MAX_PRICE_CHANGE=0.20   # circuit breaker on >20% price moves
VALIDATION_MIN_VOLUME=100
CACHE_TTL_SECONDS=300

# --------------------------------------------------------------------------
# Technical indicators
# --------------------------------------------------------------------------
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
VOLUME_SMA_PERIOD=20

# --------------------------------------------------------------------------
# Data collection
# --------------------------------------------------------------------------
DEFAULT_PERIODS=200
MIN_DATA_FOR_INDICATORS=20
RECENT_DATA_LOOKBACK=20

# --------------------------------------------------------------------------
# AI brain / history
# --------------------------------------------------------------------------
MAX_DECISION_HISTORY=100

# --------------------------------------------------------------------------
# Simulation / mock data
# --------------------------------------------------------------------------
SIMULATION_PERIODS=50
SIMULATION_BASE_PRICE=2850
MOCK_VOLUME_RANGE_MIN=100000
MOCK_VOLUME_RANGE_MAX=1000000

# --------------------------------------------------------------------------
# Performance / display
# --------------------------------------------------------------------------
DEFAULT_TRADE_HISTORY_LIMIT=50
MIN_LIQUIDITY_VOLUME=2000000
