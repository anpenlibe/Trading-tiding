# API Keys - ZERODHA ONLY
ANTHROPIC_API_KEY=your-claude-api-key-here
ZERODHA_API_KEY=your-zerodha-api-key-here
ZERODHA_API_SECRET=your-zerodha-api-secret-here
ZERODHA_ACCESS_TOKEN=your-zerodha-access-token-here

# Environment
ENVIRONMENT=development

# Trading Parameters - UPDATED FOR ₹10,000
INITIAL_CAPITAL=10000.0
MAX_RISK_PER_TRADE=0.015
MAX_DAILY_LOSS=0.05
MAX_DRAWDOWN=0.15

# Data Source
DATA_SOURCE=zerodha
USE_MOCK_DATA=false

# Claude Settings
CLAUDE_MODEL=claude-3-5-sonnet-20241022
DEBUG_MODE=false
DRY_RUN=true

# ============= NEW CONFIGURATION VARIABLES =============

# Data Validation
VALIDATION_MAX_PRICE_CHANGE=0.20  # Maximum price change before circuit breaker (0.20 = 20%)
VALIDATION_MIN_VOLUME=100         # Minimum volume to consider data valid

# Cache Settings
CACHE_TTL_SECONDS=300             # Cache time-to-live in seconds

# Technical Indicators
RSI_PERIOD=14                     # RSI calculation period
RSI_OVERBOUGHT=70                 # RSI overbought threshold
RSI_OVERSOLD=30                   # RSI oversold threshold
MACD_FAST=12                      # MACD fast EMA period
MACD_SLOW=26                      # MACD slow EMA period
MACD_SIGNAL=9                     # MACD signal line period
VOLUME_SMA_PERIOD=20              # Volume moving average period

# Data Collection
DEFAULT_PERIODS=200               # Default number of periods to fetch
MIN_DATA_FOR_INDICATORS=20        # Minimum data points needed for indicators
RECENT_DATA_LOOKBACK=20           # Recent data lookback period

# AI Brain Settings
MAX_DECISION_HISTORY=100          # Maximum number of decisions to keep in history

# Simulation Settings
SIMULATION_PERIODS=50             # Number of periods for simulation data
SIMULATION_BASE_PRICE=2850        # Base price for simulation

# Mock Data Generation
MOCK_VOLUME_RANGE_MIN=100000      # Minimum volume for mock data
MOCK_VOLUME_RANGE_MAX=1000000     # Maximum volume for mock data

# Performance Settings
DEFAULT_TRADE_HISTORY_LIMIT=50    # Default number of trades to show in history

# Liquidity Filtering
MIN_LIQUIDITY_VOLUME=2000000      # Minimum daily volume for stock selection
