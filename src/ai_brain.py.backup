Purpose: Claude API integration for AI-powered trading decisions
Author: Trading Bot Developer
Created: 2025-06-15
Modified: 2025-06-30 - Fixed parsing bugs and improved integration

This module implements the AI brain that analyzes market data and generates
trading signals using Claude API.
"""

import os
import json
import time
from datetime import datetime, timedelta
from typing import Dict, List, Any, Optional
import pandas as pd
import anthropic
from dataclasses import dataclass, asdict

from src.interfaces import BaseDecisionModel, TradingSignal
from src.config import (
    ANTHROPIC_API_KEY, CLAUDE_MODEL, CLAUDE_MAX_TOKENS, CLAUDE_TEMPERATURE,
    INITIAL_CAPITAL, MAX_RISK_PER_TRADE, STOP_LOSS_PERCENT, TAKE_PROFIT_PERCENT,
    SYMBOLS, RECENT_DATA_LOOKBACK, MAX_DECISION_HISTORY,
    SIMULATION_PERIODS, SIMULATION_BASE_PRICE
)
from src.utils.logger import setup_logger

# Initialize logger
logger = setup_logger(__name__, 'ai_brain.log')

class ClaudeAI(BaseDecisionModel):
    """
    Claude-powered AI brain for trading decisions.
    
    Analyzes market data and technical indicators to generate
    BUY/SELL/HOLD signals with confidence levels.
    """
    
    def __init__(self, api_key: Optional[str] = None):
        """Initialize Claude AI with API key"""
        self.api_key = api_key or ANTHROPIC_API_KEY
        if not self.api_key:
            raise ValueError("Anthropic API key not configured")
        
        self.client = anthropic.Anthropic(api_key=self.api_key)
        self.model = CLAUDE_MODEL
        self.decision_history = []
       
        # Initialize risk manager
        from src.risk_manager import SimpleRiskManager
        self.risk_manager = SimpleRiskManager()

        logger.info(f"Claude AI initialized with model: {self.model}")
    
    def get_required_indicators(self) -> List[str]:
        """Return list of indicators this model needs"""
        return [
            "sma_20", "sma_50", "sma_200",  # Moving averages
            "rsi_14",                        # RSI
            "macd", "macd_signal", "macd_histogram",  # MACD
            "volume_avg_20",                 # Volume analysis
            "price_change_pct"               # Price momentum
        ]
    
    def analyze(self, market_data: pd.DataFrame, 
                indicators: Dict[str, float]) -> Dict[str, Any]:
        """
        Analyze market data and indicators to generate trading signal.
        
        Args:
            market_data: Historical price data (OHLCV)
            indicators: Calculated technical indicators
            
        Returns:
            Dict containing signal, confidence, reasoning, etc.
        """
        try:
            # Prepare the analysis
            symbol = market_data['symbol'].iloc[-1] if 'symbol' in market_data else "UNKNOWN"
            current_price = float(market_data['close'].iloc[-1])
            
            # Format data for Claude
            prompt = self._create_analysis_prompt(symbol, market_data, indicators)
            
            # Get Claude's analysis
            response = self._get_claude_response(prompt)
            
            # Parse the response (FIXED: now passes symbol parameter)
            signal = self._parse_claude_response(response, current_price, symbol)
            
            # Log the decision
            self._log_decision(symbol, signal, market_data, indicators)
            
            # Convert to dict format expected by interface
            return asdict(signal)
            
        except Exception as e:
            logger.error(f"Error in AI analysis: {e}")
            # Return safe default signal
            return {
                "signal": "HOLD",
                "confidence": 0.0,
                "reasoning": f"Error in analysis: {str(e)}",
                "stop_loss": None,
                "target": None,
                "entry_price": None,
                "position_size": None,
                "risk_amount": None
            }
    
    # Replace the _create_analysis_prompt method in src/ai_brain.py with this fixed version:

    def _create_analysis_prompt(self, symbol: str, 
                            market_data: pd.DataFrame, 
                            indicators: Dict[str, float]) -> str:
        """Create a comprehensive prompt for Claude with market context"""
    
        # Helper function to safely format indicator values
        def safe_format(value, default=0, decimals=2):
            """Safely format a value that might be None"""
            if value is None or pd.isna(value):
                value = default
            try:
                return f"{float(value):.{decimals}f}"
            except (ValueError, TypeError):
                return f"{default:.{decimals}f}"
    
        # Get recent price action
        recent_data = market_data.tail(RECENT_DATA_LOOKBACK)  # Configurable lookback
        current = market_data.iloc[-1]
    
        # Calculate key metrics safely
        try:
            price_change_5d = ((current['close'] - market_data['close'].iloc[-5]) / 
                          market_data['close'].iloc[-5] * 100) if len(market_data) >= 5 else 0
        except (IndexError, KeyError, ZeroDivisionError):
            price_change_5d = 0
    
        try:
            high_20d = market_data['high'].tail(20).max() if len(market_data) >= 20 else current['high']
            low_20d = market_data['low'].tail(20).min() if len(market_data) >= 20 else current['low']
        except (KeyError, AttributeError):
            high_20d = current.get('high', current.get('close', 0))
            low_20d = current.get('low', current.get('close', 0))
    
        # Volume analysis
        current_volume = current.get('volume', 0)
        avg_volume = indicators.get('volume_avg_20', current_volume)
        try:
            volume_ratio = current_volume / avg_volume if avg_volume and avg_volume > 0 else 1.0
        except (TypeError, ZeroDivisionError):
            volume_ratio = 1.0
    
        # Safe current price
        try:
            current_price = float(current['close'])
        except (KeyError, TypeError, ValueError):
            current_price = 100.0  # Fallback price
    
        prompt = f"""You are an expert swing trading analyst for the Indian stock market (NSE). 
Analyze the following data for {symbol} and provide a trading recommendation.

CURRENT MARKET DATA:
- Symbol: {symbol}
- Current Price: ₹{current_price:.2f}
- Day Range: ₹{safe_format(current.get('low', current_price))} - ₹{safe_format(current.get('high', current_price))}
- Volume: {current_volume:,} (Ratio: {volume_ratio:.2f}x avg)
- 5-Day Change: {price_change_5d:.2f}%
- 20-Day Range: ₹{safe_format(low_20d, current_price)} - ₹{safe_format(high_20d, current_price)}

TECHNICAL INDICATORS:
- SMA 20: ₹{safe_format(indicators.get('sma_20'), current_price)}
- SMA 50: ₹{safe_format(indicators.get('sma_50'), current_price)}
- SMA 200: ₹{safe_format(indicators.get('sma_200'), current_price)}
- RSI (14): {safe_format(indicators.get('rsi_14'), 50, 1)}
- MACD: {safe_format(indicators.get('macd'), 0)}
- MACD Signal: {safe_format(indicators.get('macd_signal'), 0)}
- MACD Histogram: {safe_format(indicators.get('macd_histogram'), 0)}
- Price Change %: {safe_format(indicators.get('price_change_pct'), 0)}%

TRADING CONTEXT:
- Strategy: Swing Trading (2-5 day holds)
- Capital: ₹{INITIAL_CAPITAL}
- Max Risk: {MAX_RISK_PER_TRADE*100:.1f}% per trade
- Risk Management: Stop loss at {STOP_LOSS_PERCENT*100:.1f}%, Target at {TAKE_PROFIT_PERCENT*100:.1f}%

ANALYSIS CRITERIA:
1. Trend alignment (price vs moving averages)
2. Momentum indicators (RSI, MACD)
3. Volume confirmation
4. Risk-reward ratio
5. Clear support/resistance levels

CRITICAL: Respond ONLY with a valid JSON object in this exact format:

{{
    "signal": "BUY",
    "confidence": 0.75,
    "reasoning": "Brief explanation of your analysis",
    "entry_price": {current_price:.2f},
    "stop_loss": null,
    "target": null
}}

Valid signals: BUY, SELL, HOLD
Confidence: 0.0 to 1.0
For HOLD signals, set stop_loss and target to null.

Remember: We're swing trading with limited capital (₹{INITIAL_CAPITAL}), so capital preservation is crucial. Only suggest BUY/SELL with high confidence setups (confidence > 0.6). For lower confidence, use HOLD."""
    
        return prompt


    def _get_claude_response(self, prompt: str) -> str:
        """Get response from Claude API"""
        try:
            start_time = time.time()
            
            message = self.client.messages.create(
                model=self.model,
                max_tokens=CLAUDE_MAX_TOKENS,
                temperature=CLAUDE_TEMPERATURE,
                messages=[
                    {
                        "role": "user",
                        "content": prompt
                    }
                ]
            )
            
            response = message.content[0].text
            duration = time.time() - start_time
            
            logger.info(f"Claude response received in {duration:.2f}s")
            logger.debug(f"Response: {response[:200]}...")  # Log first 200 chars
            
            return response
            
        except Exception as e:
            logger.error(f"Claude API error: {e}")
            raise
    
    def _parse_claude_response(self, response: str, current_price: float, symbol: str = "UNKNOWN") -> TradingSignal:
        """Parse Claude's response into a TradingSignal object"""
        try:
            # Find JSON in response (Claude sometimes includes explanatory text)
            start_idx = response.find('{')
            end_idx = response.rfind('}') + 1
            
            if start_idx == -1 or end_idx == 0:
                raise ValueError("No JSON found in response")
            
            json_str = response[start_idx:end_idx]
            data = json.loads(json_str)
            
            # Extract signal data
            signal = data.get('signal', 'HOLD').upper()
            confidence = float(data.get('confidence', 0.5))
            reasoning = data.get('reasoning', 'No reasoning provided')
            
            # Ensure signal is valid
            if signal not in ['BUY', 'SELL', 'HOLD']:
                signal = 'HOLD'
                confidence = 0.0
            
            # Use risk manager for position calculations
            stop_loss = None
            target = None
            position_size = None
            risk_amount = None
            entry_price = float(data.get('entry_price', current_price))
            
            if signal in ['BUY', 'SELL']:
                # Let risk manager calculate everything
                risk_params = self.risk_manager.calculate_risk_parameters(
                    symbol=symbol,
                    signal_type=signal,
                    entry_price=entry_price,
                    capital=INITIAL_CAPITAL,  # Or self.capital if using optimized version
                    stop_loss=data.get('stop_loss'),  # Use Claude's suggestion if provided
                    target=data.get('target')          # Use Claude's suggestion if provided
                )
                
                # Extract calculated values
                stop_loss = risk_params.stop_loss
                target = risk_params.target
                position_size = risk_params.position_size
                risk_amount = risk_params.risk_amount
                entry_price = risk_params.entry_price  # Includes slippage
            
            return TradingSignal(
                signal=signal,
                confidence=confidence,
                reasoning=reasoning,
                stop_loss=stop_loss,
                target=target,
                entry_price=entry_price,
                position_size=position_size,
                risk_amount=risk_amount
            )
            
        except Exception as e:
            logger.error(f"Error parsing Claude response: {e}")
            logger.debug(f"Response that failed to parse: {response[:200]}...")
            return TradingSignal(
                signal="HOLD",
                confidence=0.0,
                reasoning=f"Failed to parse response: {str(e)}"
            )
    
    def _log_decision(self, symbol: str, signal: TradingSignal, 
                      market_data: pd.DataFrame, indicators: Dict[str, float]):
        """Log the trading decision for analysis"""
        decision_log = {
            "timestamp": datetime.now().isoformat(),
            "symbol": symbol,
            "signal": signal.signal,
            "confidence": signal.confidence,
            "reasoning": signal.reasoning,
            "entry_price": signal.entry_price,
            "stop_loss": signal.stop_loss,
            "target": signal.target,
            "position_size": signal.position_size,
            "risk_amount": signal.risk_amount,
            "market_data": {
                "current_price": float(market_data['close'].iloc[-1]),
                "volume": int(market_data['volume'].iloc[-1]),
                "daily_change": float(
                    (market_data['close'].iloc[-1] - market_data['open'].iloc[-1]) / 
                    market_data['open'].iloc[-1] * 100
                )
            },
            "indicators": indicators
        }
        
        # Save to file
        log_dir = os.path.join(os.path.dirname(os.path.dirname(__file__)), 'data', 'logs')
        os.makedirs(log_dir, exist_ok=True)
        
        log_file = os.path.join(log_dir, 'ai_decisions.json')
        with open(log_file, 'a') as f:
            f.write(json.dumps(decision_log) + '\n')
        
        # Keep in memory for recent access
        self.decision_history.append(decision_log)
        if len(self.decision_history) > MAX_DECISION_HISTORY:  # Keep configurable history
            self.decision_history.pop(0)
        
        logger.info(f"Decision logged: {symbol} - {signal.signal} (confidence: {signal.confidence:.2f})")
    
    def get_recent_decisions(self, symbol: Optional[str] = None, limit: int = 10) -> List[Dict]:
        """Get recent trading decisions for analysis"""
        decisions = self.decision_history
        
        if symbol:
            decisions = [d for d in decisions if d['symbol'] == symbol]
        
        return decisions[-limit:]


# Alternative decision models for comparison
class SimpleRuleBasedModel(BaseDecisionModel):
    """
    Simple rule-based model for comparison with AI.
    Uses basic technical analysis rules.
    """
    
    def get_required_indicators(self) -> List[str]:
        """Return list of indicators this model needs"""
        return ["sma_20", "sma_50", "rsi_14", "volume_avg_20"]
    
    def analyze(self, market_data: pd.DataFrame, 
                indicators: Dict[str, float]) -> Dict[str, Any]:
        """
        Simple rule-based analysis:
        - Buy: Price > SMA20 > SMA50 and RSI < 70
        - Sell: Price < SMA20 < SMA50 or RSI > 70
        - Hold: Otherwise
        """
        current_price = float(market_data['close'].iloc[-1])
        sma_20 = indicators.get('sma_20', current_price)
        sma_50 = indicators.get('sma_50', current_price)
        rsi = indicators.get('rsi_14', 50)
        
        signal = "HOLD"
        confidence = 0.5
        reasoning = ""
        
        # Bullish setup
        if current_price > sma_20 > sma_50 and rsi < 70:
            signal = "BUY"
            confidence = 0.7
            reasoning = "Bullish trend with room to grow (RSI not overbought)"
        
        # Bearish setup
        elif current_price < sma_20 < sma_50:
            signal = "SELL"
            confidence = 0.7
            reasoning = "Bearish trend confirmed by moving averages"
        
        # Overbought
        elif rsi > 70:
            signal = "SELL"
            confidence = 0.6
            reasoning = "RSI indicates overbought conditions"
        
        # Calculate stops and targets
        stop_loss = None
        target = None
        
        if signal == "BUY":
            stop_loss = current_price * (1 - STOP_LOSS_PERCENT)
            target = current_price * (1 + TAKE_PROFIT_PERCENT)
        elif signal == "SELL":
            stop_loss = current_price * (1 + STOP_LOSS_PERCENT)
            target = current_price * (1 - TAKE_PROFIT_PERCENT)
        
        return {
            "signal": signal,
            "confidence": confidence,
            "reasoning": reasoning,
            "stop_loss": stop_loss,
            "target": target
        }


def main():
    """Test the AI brain with sample data"""
    print("Testing AI Brain...")
    
    # Create sample market data
    import numpy as np
    dates = pd.date_range(end=datetime.now(), periods=SIMULATION_PERIODS, freq='5min')
    
    # Generate realistic price movement
    base_price = SIMULATION_BASE_PRICE  # Configurable base price
    returns = np.random.normal(0.0002, 0.01, SIMULATION_PERIODS)  # Small random returns
    prices = base_price * (1 + returns).cumprod()
    
    market_data = pd.DataFrame({
        'timestamp': dates,
        'open': prices * (1 + np.random.uniform(-0.001, 0.001, SIMULATION_PERIODS)),
        'high': prices * (1 + np.random.uniform(0, 0.005, SIMULATION_PERIODS)),
        'low': prices * (1 - np.random.uniform(0, 0.005, SIMULATION_PERIODS)),
        'close': prices,
        'volume': np.random.randint(100000, 500000, SIMULATION_PERIODS),
        'symbol': 'RELIANCE'
    })
    
    # Sample indicators
    indicators = {
        'sma_20': prices[-RECENT_DATA_LOOKBACK:].mean(),
        'sma_50': prices.mean(),
        'rsi_14': 45.5,  # Slightly oversold
        'macd': 2.5,
        'macd_signal': 1.8,
        'macd_histogram': 0.7,
        'volume_avg_20': 300000,
        'price_change_pct': 1.2
    }
    
    # Test Claude AI
    try:
        ai = ClaudeAI()
        decision = ai.analyze(market_data, indicators)
        
        print("\n=== Claude AI Decision ===")
        print(f"Signal: {decision['signal']}")
        print(f"Confidence: {decision['confidence']:.2f}")
        print(f"Reasoning: {decision['reasoning']}")
        print(f"Stop Loss: ₹{decision.get('stop_loss', 'N/A')}")
        print(f"Target: ₹{decision.get('target', 'N/A')}")
        
    except Exception as e:
        print(f"Claude AI test failed: {e}")
    
    # Test rule-based model for comparison
    print("\n=== Rule-Based Decision ===")
    rule_model = SimpleRuleBasedModel()
    rule_decision = rule_model.analyze(market_data, indicators)
    
    print(f"Signal: {rule_decision['signal']}")
    print(f"Confidence: {rule_decision['confidence']:.2f}")
    print(f"Reasoning: {rule_decision['reasoning']}")


if __name__ == "__main__":
    main()
